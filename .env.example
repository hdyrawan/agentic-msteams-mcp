# Microsoft Teams Configuration
MSTEAMS_INBOUND_SHARED_SECRET=""
MSTEAMS_REQUIRE_INBOUND_AUTH=True
TEAMS_APP_ID="your-app-id-here"
TEAMS_APP_PASSWORD="your-app-password-here"

# Notification Control
MSTEAMS_NOTIFICATION_DRY_RUN=True
MSTEAMS_ALLOWED_USER_IDS="user1,user2"
MSTEAMS_ALLOWED_CHANNEL_IDS="chan1,chan2"
MSTEAMS_AUDIT_LOG_PATH="data/notifications_audit.log"

# Server Configuration
SERVER_HOST="localhost"
SERVER_PORT=8000

# MCP Configuration  
MCP_SERVER_HOST="localhost"
MCP_SERVER_PORT=8001

# Logging Configuration
LOG_LEVEL="INFO"

# Development Flags
DEBUG=False
